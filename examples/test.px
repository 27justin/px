
let some_value: i32 = zero
var another_value: i32 = zero

printf := @(extern: "C", import: "printf") fn (_: !u8, ..) -> i32

testfn := fn () -> bool {
  defer printf("test\n");

  if false {
    return false;
  }

  var i: i64 = 0;
  while i < 10 {
    if i > 5 {
      return false;
    }
    i = i + 1;
  }

  false
}

main := fn () -> i32 {
  testfn();
  0
}
